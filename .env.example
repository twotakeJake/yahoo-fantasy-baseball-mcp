# Yahoo OAuth credentials
YAHOO_CLIENT_ID=your_yahoo_client_id_here
YAHOO_CLIENT_SECRET=your_yahoo_client_secret_here

# Populated automatically by: npm run get-token
YAHOO_ACCESS_TOKEN=your_access_token_here
YAHOO_REFRESH_TOKEN=your_refresh_token_here

# Your fantasy league settings (league ID is in your Yahoo league URL)
YAHOO_LEAGUE_ID=your_league_id_here
YAHOO_TEAM_NUMBER=your_team_number_here
YAHOO_TEAM_NAME=your_team_name_here
